PORT=3000
NODE_ENV=development

DB_HOST=ep-your-project.region.aws.neon.tech
DB_PORT=5432
DB_USERNAME=neondb_owner
DB_PASSWORD=your-neon-password
DB_NAME=neondb
DB_SSL=true

JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=30m
JWT_SESSION_EXPIRES_IN=30m
JWT_REMEMBER_EXPIRES_IN=30d
JWT_REFRESH_SECRET=change-me-to-a-long-random-refresh-secret-at-least-32-chars
JWT_REFRESH_SESSION_EXPIRES_IN=30m
JWT_REFRESH_REMEMBER_EXPIRES_IN=30d
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-gmail-app-password
EMAIL_FROM=Orbit <your@gmail.com>

FRONTEND_URL=http://localhost:5173

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_REFUND_WINDOW_DAYS=7

CURSOR_API_KEY=crsr_your_cursor_api_key
CURSOR_MODEL=composer-2.5

# BullMQ (set QUEUE_ENABLED=true when Redis is available)
QUEUE_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# Rate limiting + Sentry (optional)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# LEADS_INBOX_EMAIL=sales@orbit.io

SUPER_ADMIN_EMAIL=admin09068@yopmail.com
SUPER_ADMIN_PASSWORD=change-me-strong-password
